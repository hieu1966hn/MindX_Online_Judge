# =============================================================================
# MindX Online Judge — Environment Variables (Local-First MVP)
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file to version control.
#
# For the local-first MVP, only DATABASE_URL, SECRET_KEY, and
# NEXT_PUBLIC_API_URL are required. Everything else has sensible defaults
# or is optional.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# SQLite connection URL used by the API server and Alembic migrations.
# The database file will be created automatically at api-server/data/mindx.db.
# No PostgreSQL or Docker required for the MVP.
DATABASE_URL=sqlite:///./data/mindx.db

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Secret key used to sign and verify JWT access tokens (HS256).
# Generate a strong random value, e.g.: openssl rand -hex 32
SECRET_KEY=replace-with-a-strong-random-secret-key

# -----------------------------------------------------------------------------
# Frontend / Next.js
# -----------------------------------------------------------------------------

# Public base URL of the FastAPI backend, accessible from the browser.
# Used by the Next.js app to make API requests.
# In production, set this to your actual API domain (e.g. https://api.mindxjudge.vn).
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# File System Paths
# -----------------------------------------------------------------------------

# Path to the directory containing problem packages (problem.yaml + testcases).
# Relative to the api-server/ working directory.
PROBLEM_PACKAGES_DIR=../problem-packages

# Path to the directory where submitted source code files are stored.
# Relative to the api-server/ working directory.
SUBMISSIONS_DIR=../storage/submissions

# -----------------------------------------------------------------------------
# Email / SMTP (Optional — password reset emails)
# -----------------------------------------------------------------------------
# These variables are optional for the MVP. If not set, password reset tokens
# are logged to the console instead of being emailed.

# Hostname of the SMTP server used to send password reset emails.
# SMTP_HOST=smtp.example.com

# Port of the SMTP server. Common values: 587 (STARTTLS), 465 (SSL), 25 (plain).
# SMTP_PORT=587

# Username (usually the sender email address) for SMTP authentication.
# SMTP_USER=noreply@example.com

# Password for SMTP authentication.
# SMTP_PASSWORD=smtp-password-here

# =============================================================================
# Production Hardening (not required for MVP)
# =============================================================================
# Uncomment and configure these when upgrading to a production deployment
# with PostgreSQL and Redis. See docs/decision-log.md for the upgrade path.

# Full PostgreSQL connection URL — replaces DATABASE_URL above.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# DATABASE_URL=postgresql://mindx:changeme@localhost:5432/mindx_judge

# Password for the PostgreSQL database user (used by Docker Compose db service).
# DB_PASSWORD=changeme

# Redis connection URL for rate limiting, token blacklisting, and job queuing.
# Format: redis://<host>:<port>/<db>
# REDIS_URL=redis://localhost:6379/0
